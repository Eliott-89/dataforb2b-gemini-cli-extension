  "contextFileName": "GEMINI.md",
  "mcpServers": {
    "dataforb2b": {
      "httpUrl": "https://mcp.dataforb2b.ai/mcp",
      "timeout": 30000,
      "headers": {
        "Authorization": "Bearer ${DATAFORB2B_API_KEY}"
      },
      "includeTools": [
        "search_natural_language",
        "enrich_profile",
        "enrich_company",
        "search_lookalike",
        "find_email"
      ]
    }
  }
}
